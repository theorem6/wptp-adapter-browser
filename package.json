  "files": [
    "dist"
  ],
  "dependencies": {
    "@wptp/ir": "file:../wptp-ir"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.22.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
