{
  "name": "@wptp/adapter-browser",
  "version": "0.1.0",
  "description": "Lift browser HAR traces into WPTP IR v0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theorem6/wptp-adapter-browser.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
